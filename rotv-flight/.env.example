# ---------------------------------------------------------------------------
# ROTV Flight — environment variables
# Copy this file to .env and adjust values for your environment.
# ---------------------------------------------------------------------------

# Set to "true" to connect to a live ConnectRPC/gRPC server.
# Set to "false" (default) to run with static mock data only — no server needed.
VITE_USE_GRPC=false

# Base URL of the ConnectRPC server the frontend connects to.
# Only used when VITE_USE_GRPC=true.
# For the bundled dev server run "npm run server:dev" — it listens on port 4001.
# Point this at a remote server URL when integrating with real hardware or a
# backend team's gRPC implementation.
VITE_GRPC_BASE_URL=http://localhost:4001
